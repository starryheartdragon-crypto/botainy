# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=



# OpenRouter
OPENROUTER_API_KEY=
# Primary model (used for all AI completions)
OPENROUTER_MODEL=openrouter/hunter-alpha
# Fallback model (used automatically if the primary model fails)
OPENROUTER_FALLBACK_MODEL=openai/gpt-4-turbo

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional smoke test settings for CI (set in GitHub secrets, not here)
# SMOKE_BASE_URL=
# SMOKE_AUTH_TOKEN=
# SMOKE_BOT_ID=
# SMOKE_PERSONA_ID=
